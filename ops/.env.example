# Copy to ops/.env on the server. Never commit the real file.

# Random 32+ bytes, e.g. `openssl rand -base64 48`
AUTH_SECRET=replace-me

# Public URL (matches GitHub OAuth app callback host)
AUTH_URL=https://amorson.me
NEXTAUTH_URL=https://amorson.me

# GitHub OAuth app:
#   Homepage URL     https://amorson.me
#   Callback URL     https://amorson.me/api/auth/callback/github
AUTH_GITHUB_ID=replace-me
AUTH_GITHUB_SECRET=replace-me

# Comma-separated GitHub logins allowed to sign in.
AUTH_ALLOWED_GITHUB_LOGINS=mk-amorson
