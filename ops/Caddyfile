# Octopus / amorson.me reverse proxy.
# Auto-HTTPS via Let's Encrypt. Only the apex domain — no www.

{
	email admin@amorson.me
}

amorson.me {
	encode zstd gzip

	# OpenClaw Control UI + Gateway WebSocket. Caddy v2 forwards the
	# Upgrade/Connection headers for WebSocket automatically, so no extra
	# header_up directives are needed. OpenClaw itself must be configured
	# to trust this proxy and accept the public origin — see README.
	reverse_proxy 127.0.0.1:18789
}
