# amorson.me reverse proxy. Auto-HTTPS via Let's Encrypt.

{
	email admin@amorson.me
}

# Apex — placeholder for future projects.
amorson.me {
	encode zstd gzip
	respond "Octopus online" 200
}

# OpenClaw Control UI + Gateway WebSocket. Caddy v2 forwards Upgrade/
# Connection headers automatically. OpenClaw must trust the proxy and
# accept this origin — handled by scripts/configure-openclaw.sh.
claw.amorson.me {
	encode zstd gzip
	reverse_proxy 127.0.0.1:18789
}
