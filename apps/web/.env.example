# For local dev. Copy to apps/web/.env.local.

AUTH_SECRET=dev-secret-replace-me-with-random-bytes
AUTH_URL=http://localhost:3000

# GitHub OAuth app (for local dev, create a separate one with callback
# http://localhost:3000/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

AUTH_ALLOWED_GITHUB_LOGINS=your-github-login
